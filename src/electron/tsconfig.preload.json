{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": false,
    "sourceMap": true,
    "declaration": false,
    "outDir": "../../dist/electron",
    "rootDir": ".",
    "baseUrl": "../",
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "preload.ts",
    "../shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "../../dist"
  ]
}
