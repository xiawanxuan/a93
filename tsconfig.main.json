{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": false,
    "sourceMap": true,
    "declaration": false,
    "outDir": "./dist/electron",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": [
    "src/electron/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/renderer"
  ]
}
